+	if (modifiers & terminal->text_input_alt_mask)
+		terminal_modifiers |= MOD_ALT_MASK;
+	if (modifiers & terminal->text_input_control_mask)
+		terminal_modifiers |= MOD_CONTROL_MASK;
+
+	length = terminal_encode_key(terminal, key, terminal_modifiers, response);
+	if (length <= 0)
+		return;
+
+	if (terminal->scrolling) {
+		d = terminal->saved_start - terminal->start;
+		terminal->row -= d;
+		terminal->selection_start_row -= d;
+		terminal->selection_end_row -= d;
+		terminal->start = terminal->saved_start;
+		terminal->scrolling = 0;
