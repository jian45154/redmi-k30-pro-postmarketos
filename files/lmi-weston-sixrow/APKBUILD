# Maintainer: Local lmi port work <noreply@example.invalid>
pkgname=lmi-weston-sixrow-clients
pkgver=14.0.2
pkgrel=2
pkgdesc="Hash-locked six-row Weston keyboard and text-input terminal for xiaomi-lmi"
url="https://gitlab.freedesktop.org/wayland/weston"
arch="aarch64"
license="MIT"
makedepends="
	cairo-dev
	eudev-dev
	libdrm-dev
	libevdev-dev
	libinput-dev
	libpng-dev
	libxkbcommon-dev
	meson
	pango-dev
	pixman-dev
	wayland-dev
	wayland-protocols
	"
options="!check"
source="
	https://gitlab.freedesktop.org/wayland/weston/-/releases/$pkgver/downloads/weston-$pkgver.tar.xz
	0001-phone-input-terminal-text-input.patch
	0002-sixrow-control.patch
	0003-sixrow-paged-touch.patch
	"
builddir="$srcdir/weston-$pkgver"

build() {
	abuild-meson \
		-Dbackend-default=headless \
		-Dbackend-drm=false \
		-Dbackend-drm-screencast-vaapi=false \
		-Dbackend-headless=true \
		-Dbackend-pipewire=false \
		-Dbackend-rdp=false \
		-Dbackend-vnc=false \
		-Dbackend-wayland=false \
		-Dbackend-x11=false \
		-Dcolor-management-lcms=false \
		-Ddemo-clients=false \
		-Ddoc=false \
		-Dimage-jpeg=false \
		-Dimage-webp=false \
		-Dpipewire=false \
		-Drenderer-gl=false \
		-Dremoting=false \
		-Dscreenshare=false \
		-Dshell-desktop=true \
		-Dshell-fullscreen=false \
		-Dshell-ivi=false \
		-Dshell-kiosk=false \
		-Dsimple-clients=[] \
		-Dsystemd=false \
		-Dtests=false \
		-Dtools=terminal \
		-Dwcap-decode=false \
		-Dxwayland=false \
		build

	# Do not run the default/all target: only these two client executables
	# are compiled, and package() below intentionally does not run meson install.
	meson compile -C build weston-keyboard weston-terminal
}

package() {
	install -Dm755 build/clients/weston-keyboard \
		"$pkgdir/usr/libexec/lmi-p2-d114/weston-keyboard-sixrow"
	install -Dm755 build/clients/weston-terminal \
		"$pkgdir/usr/libexec/lmi-p2-d114/weston-terminal-sixrow"
}

