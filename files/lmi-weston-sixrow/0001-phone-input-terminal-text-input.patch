 static void
+terminal_text_input_commit_string(void *data,
+				  struct zwp_text_input_v1 *text_input,
+				  uint32_t serial, const char *text)
+{
+	struct terminal *terminal = data;
+
+	size_t preedit_length;
+
+	if (terminal->text_input_preedit && text) {
+		preedit_length = strlen(terminal->text_input_preedit);
+		if (strlen(text) >= preedit_length &&
+		    strncmp(terminal->text_input_preedit, text,
+			    preedit_length) == 0) {
+			if (text[preedit_length])
+				terminal_write(terminal, text + preedit_length,
+					       strlen(text + preedit_length));
+			free(terminal->text_input_preedit);
+			terminal->text_input_preedit = NULL;
+			return;
+		}
+	}
+
+	free(terminal->text_input_preedit);
+	terminal->text_input_preedit = NULL;
+
+	if (text && text[0])
+		terminal_write(terminal, text, strlen(text));
+}
+
+static void
+terminal_text_input_delete_surrounding_text(void *data,
+					       struct zwp_text_input_v1 *text_input,
+					       int32_t index, uint32_t length)
+{
+	struct terminal *terminal = data;
+
+	(void)index;
+	while (length-- > 0)
+		terminal_write(terminal, "\177", 1);
+}
+
+static void
+terminal_text_input_keysym(void *data, struct zwp_text_input_v1 *text_input,
+			   uint32_t serial, uint32_t time, uint32_t key,
+			   uint32_t state, uint32_t modifiers)
+{
+	struct terminal *terminal = data;
+	const char *sequence = NULL;
+	char text[8];
+	int length;
+
+	if (state != WL_KEYBOARD_KEY_STATE_RELEASED)
+		return;
+
+	switch (key) {
+	case XKB_KEY_Return:
+	case XKB_KEY_KP_Enter:
+		sequence = (terminal->mode & MODE_LF_NEWLINE) ? "\r\n" : "\r";
+		break;
+	case XKB_KEY_Tab:
+		sequence = "\t";
+		break;
+	case XKB_KEY_Escape:
+		sequence = "\033";
+		break;
+	case XKB_KEY_Left:
+		sequence = "\033[D";
+		break;
+	case XKB_KEY_Right:
+		sequence = "\033[C";
+		break;
+	case XKB_KEY_Up:
+		sequence = "\033[A";
+		break;
+	case XKB_KEY_Down:
+		sequence = "\033[B";
+		break;
+	case XKB_KEY_Home:
+		sequence = "\033[H";
+		break;
+	case XKB_KEY_End:
+		sequence = "\033[F";
+		break;
+	case XKB_KEY_Delete:
+		sequence = "\033[3~";
+		break;
+	default:
+		length = xkb_keysym_to_utf8(key, text, sizeof text);
+		if (length > 0)
+			terminal_write(terminal, text, length);
+		return;
+	}
+
+	terminal_write(terminal, sequence, strlen(sequence));
+}
