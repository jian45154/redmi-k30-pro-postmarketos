+static struct touch_slot *
+touch_slot_find(struct keyboard *keyboard, int32_t id)
+{
+	int i;
+
+	for (i = 0; i < MAX_TOUCH_SLOTS; ++i)
+		if (keyboard->touches[i].active &&
+		    keyboard->touches[i].id == id)
+			return &keyboard->touches[i];
+
+	return NULL;
+}
+
+static struct touch_slot *
+touch_slot_take(struct keyboard *keyboard, int32_t id)
+{
+	struct touch_slot *slot = touch_slot_find(keyboard, id);
+	int i;
+
+	if (slot)
+		return slot;
+
+	for (i = 0; i < MAX_TOUCH_SLOTS; ++i)
+		if (!keyboard->touches[i].active)
+			return &keyboard->touches[i];
+
+	return NULL;
+}
