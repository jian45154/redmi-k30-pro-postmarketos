+static int
+key_index_from_position(const struct layout *layout, double x, double y)
+{
+	unsigned int i;
+	int row, cell, col;
+
+	x /= keyboard_scale_x;
+	y /= keyboard_scale_y;
+	if (x < 0 || y < 0)
+		return -1;
+
+	row = (int)(y / key_height);
+	cell = (int)(x / key_width);
+	if (row >= (int)layout->rows || cell >= (int)layout->columns)
+		return -1;
+
+	col = cell + row * layout->columns;
+	for (i = 0; i < layout->count; ++i) {
+		col -= layout->keys[i].width;
+		if (col < 0)
+			return (int)i;
 	}
 
-	return "";
+	return -1;
+}
+
+static void
+key_row_col(const struct layout *layout, int index,
+	    unsigned int *row_out, unsigned int *col_out)
+{
+	unsigned int i, row = 0, col = 0;
+
+	for (i = 0; i < (unsigned int)index && i < layout->count; ++i) {
+		col += layout->keys[i].width;
+		if (col >= layout->columns) {
+			row += 1;
+			col = 0;
+		}
+	}
+
+	*row_out = row;
+	*col_out = col;
+}
