+static void
+terminal_text_input_preedit_string(void *data,
+				   struct zwp_text_input_v1 *text_input,
+				   uint32_t serial, const char *text, const char *commit)
+{
+	struct terminal *terminal = data;
+	const char *previous = terminal->text_input_preedit ?
+		terminal->text_input_preedit : "";
+	size_t old_length = strlen(previous);
+	size_t new_length = strlen(text);
+	size_t common = 0;
+
+	while (common < old_length && common < new_length &&
+	       previous[common] == text[common])
+		common++;
+
+	while (old_length > common) {
+		terminal_write(terminal, "\177", 1);
+		old_length--;
+	}
+	if (text[common])
+		terminal_write(terminal, text + common, new_length - common);
+
+	free(terminal->text_input_preedit);
+	terminal->text_input_preedit = strdup(text);
+}
+
