# Reference: <https://postmarketos.org/devicepkg>
maintainer=""
pkgname=device-xiaomi-lmi
pkgdesc="xiaomi lmi"
pkgver=1
pkgrel=144
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck !fhs"
install="$pkgname.post-install"
depends="
	alsa-utils
	bluez
	bluez-deprecated
	evtest
	iw
	kmscube
	libdrm-tests
	linux-xiaomi-lmi
	mesa-demos
	mesa-utils
	mkbootimg
	pd-mapper
	pd-mapper-openrc
	postmarketos-base
	postmarketos-base-downstream
	qrtr
	rmtfs
	seatd
	seatd-openrc
	tinydm
	tqftpserv
	weston
	weston-backend-drm
	weston-clients
	weston-shell-desktop
	weston-terminal
	wpa_supplicant
"
makedepends="devicepkg-dev"
source="
	deviceinfo
	initramfs_mount_firmware.sh
	lmi-android-prop-shim.c
	lmi-cnss-daemon.initd
	lmi-cnss-daemon-wrapper
	lmi-cnss-fs-ready.initd
	lmi-display-probe
	lmi-display-takeover
	lmi-firmware-mount.initd
	lmi-greetd-log
	lmi-greetd-config.toml
	lmi-phosh-session-log
	lmi-power-panel
	lmi-power-panel.initd
	lmi-qrtr-ns
	lmi-qrtr-ns.initd
	lmi-rootctl
	lmi-rootctl.sudoers
	lmi-seatd.initd
	lmi-seatd-wrapper
	lmi-splash-release
	lmi-splash-release.initd
	lmi-splash-release-wrapper
	lmi-weston.initd
	lmi-weston-wrapper
	lmi-wifi-start
	lmi-wlan-firmware.confd
	lmi-wlan-on.initd
	modules-initfs
	weston.ini
"

build() {
	devicepkg_build $startdir $pkgname
	${CC:-gcc} -shared -fPIC -nostdlib \
		-Wl,-soname,liblmi_android_prop_shim.so \
		-o "$srcdir"/liblmi_android_prop_shim.so \
		"$srcdir"/lmi-android-prop-shim.c
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm755 "$srcdir"/lmi-firmware-mount.initd \
		"$pkgdir"/etc/init.d/lmi-firmware-mount
	install -Dm755 "$srcdir"/lmi-power-panel \
		"$pkgdir"/usr/sbin/lmi-power-panel
	install -Dm755 "$srcdir"/lmi-power-panel.initd \
		"$pkgdir"/etc/init.d/lmi-power-panel
	install -Dm755 "$srcdir"/lmi-cnss-daemon.initd \
		"$pkgdir"/etc/init.d/lmi-cnss-daemon
	install -Dm755 "$srcdir"/lmi-cnss-daemon-wrapper \
		"$pkgdir"/usr/sbin/lmi-cnss-daemon-wrapper
	install -Dm755 "$srcdir"/liblmi_android_prop_shim.so \
		"$pkgdir"/usr/lib/lmi/liblmi_android_prop_shim.so
	install -Dm755 "$srcdir"/lmi-display-probe \
		"$pkgdir"/usr/sbin/lmi-display-probe
	install -Dm755 "$srcdir"/lmi-display-takeover \
		"$pkgdir"/usr/sbin/lmi-display-takeover
	install -Dm755 "$srcdir"/lmi-qrtr-ns \
		"$pkgdir"/usr/sbin/lmi-qrtr-ns
	install -Dm755 "$srcdir"/lmi-qrtr-ns.initd \
		"$pkgdir"/etc/init.d/lmi-qrtr-ns
	install -Dm755 "$srcdir"/lmi-rootctl \
		"$pkgdir"/usr/sbin/lmi-rootctl
	install -Dm440 "$srcdir"/lmi-rootctl.sudoers \
		"$pkgdir"/etc/sudoers.d/90-xiaomi-lmi-rootctl
	install -Dm755 "$srcdir"/lmi-seatd.initd \
		"$pkgdir"/etc/init.d/lmi-seatd
	install -Dm755 "$srcdir"/lmi-seatd-wrapper \
		"$pkgdir"/usr/sbin/lmi-seatd-wrapper
	install -Dm755 "$srcdir"/lmi-splash-release \
		"$pkgdir"/usr/sbin/lmi-splash-release.real
	install -Dm755 "$srcdir"/lmi-splash-release-wrapper \
		"$pkgdir"/usr/sbin/lmi-splash-release
	install -Dm755 "$srcdir"/lmi-greetd-log \
		"$pkgdir"/usr/local/bin/lmi-greetd-log
	install -Dm755 "$srcdir"/lmi-phosh-session-log \
		"$pkgdir"/usr/local/bin/lmi-phosh-session-log
	install -Dm755 "$srcdir"/lmi-splash-release.initd \
		"$pkgdir"/etc/init.d/lmi-splash-release
	install -Dm644 "$srcdir"/lmi-greetd-config.toml \
		"$pkgdir"/etc/greetd/config.toml
	install -Dm755 "$srcdir"/lmi-weston.initd \
		"$pkgdir"/etc/init.d/lmi-weston
	install -Dm755 "$srcdir"/lmi-weston-wrapper \
		"$pkgdir"/usr/sbin/lmi-weston-wrapper
	install -Dm755 "$srcdir"/lmi-cnss-fs-ready.initd \
		"$pkgdir"/etc/init.d/lmi-cnss-fs-ready
	install -Dm755 "$srcdir"/lmi-wlan-on.initd \
		"$pkgdir"/etc/init.d/lmi-wlan-on
	install -Dm755 "$srcdir"/lmi-wifi-start \
		"$pkgdir"/usr/sbin/lmi-wifi-start
	install -Dm644 "$srcdir"/weston.ini \
		"$pkgdir"/etc/xdg/weston/weston.ini
	install -Dm644 "$srcdir"/lmi-wlan-firmware.confd \
		"$pkgdir"/etc/conf.d/lmi-wlan-firmware
	install -Dm755 "$srcdir"/initramfs_mount_firmware.sh \
		-t "$pkgdir"/usr/share/mkinitfs/hooks-cleanup/
	install -dm755 "$pkgdir"/etc/runlevels/boot
	install -dm755 "$pkgdir"/etc/runlevels/default
	ln -s /etc/init.d/lmi-firmware-mount \
		"$pkgdir"/etc/runlevels/boot/lmi-firmware-mount
	ln -s /etc/init.d/lmi-qrtr-ns \
		"$pkgdir"/etc/runlevels/default/lmi-qrtr-ns
	ln -s /etc/init.d/lmi-cnss-daemon \
		"$pkgdir"/etc/runlevels/default/lmi-cnss-daemon
	ln -s /etc/init.d/pd-mapper "$pkgdir"/etc/runlevels/default/pd-mapper
	ln -s /etc/init.d/lmi-seatd "$pkgdir"/etc/runlevels/default/lmi-seatd
	ln -s /etc/init.d/lmi-splash-release "$pkgdir"/etc/runlevels/default/lmi-splash-release
	ln -s /etc/init.d/lmi-power-panel "$pkgdir"/etc/runlevels/default/lmi-power-panel
	ln -s /etc/init.d/rmtfs "$pkgdir"/etc/runlevels/default/rmtfs
	ln -s /etc/init.d/tqftpserv "$pkgdir"/etc/runlevels/default/tqftpserv
	ln -s /etc/init.d/lmi-cnss-fs-ready \
		"$pkgdir"/etc/runlevels/default/lmi-cnss-fs-ready
	ln -s /etc/init.d/lmi-wlan-on \
		"$pkgdir"/etc/runlevels/default/lmi-wlan-on
}

