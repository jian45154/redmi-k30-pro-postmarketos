# Maintainer: Nikroks <nikroks@mainlining.org>
pkgname=firmware-xiaomi-lmi
pkgver=1
pkgrel=0
pkgdesc="Firmware for lmi"
url="https://github.com/yuweiyuan8/firmware-xiaomi-lmi"
arch="aarch64"
license="proprietary"
options="!strip !check !archcheck !tracedeps textrels pmb:cross-native"

_commit="dde156380b2ac372619ed332dbe60640b838b7fe"

source="
	$pkgname.tar.gz::https://github.com/yuweiyuan8/firmware-xiaomi-lmi/archive/dde156380b2ac372619ed332dbe60640b838b7fe/firmware-xiaomi-lmi-dde156380b2ac372619ed332dbe60640b838b7fe.tar.gz
	30-initramfs-firmware.files
	firmware.files
	sensor.files
"

subpackages="$pkgname-sensors:firmware_sensors"

package() {
	while IFS="" read -r _i || [ -n "$_i" ]; do
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname $_i)
		install -Dm644 "$srcdir/$pkgname-$_commit/$_i" "$pkgdir/$_i"
	done < "$srcdir/firmware.files"

	install -Dm644 "$srcdir/30-initramfs-firmware.files" -t \
		"$pkgdir"/usr/share/mkinitfs/files
}

firmware_sensors() {
	pkgdesc="Files to be included to add sensor support"
	depends="$pkgname"
	install_if="$pkgname-nonfree-firmware"
	mkdir "$subpkgdir"

	while IFS="" read -r _i || [ -n "$_i" ]; do
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname $_i)
		install -Dm644 "$srcdir/$pkgname-$_commit/$_i" "$pkgdir/$_i"
	done < "$srcdir/sensor.files"
}
