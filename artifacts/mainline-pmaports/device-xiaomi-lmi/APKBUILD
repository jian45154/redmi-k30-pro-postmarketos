# Reference: <https://postmarketos.org/devicepkg>
# Maintainer: Nikroks <nikroksm@mail.ru>
pkgname=device-xiaomi-lmi
pkgdesc="Xiaomi POCO F2 Pro"
pkgver=1
pkgrel=1
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-conf
	bootmac
	hexagonrpcd
	make-dynpart-mappings
	mesa-vulkan-freedreno
	mkbootimg
	swclock-offset
	linux-postmarketos-qcom-sm8250-lmi
	postmarketos-base
	qbootctl
"
makedepends="devicepkg-dev"
source="
	81-libssc-xiaomi-lmi.rules
	alsa-ucm-conf/lmi.conf
	alsa-ucm-conf/HiFi.conf
	deviceinfo
	hexagonrpcd.confd
	modules-initfs
	firmware-xiaomi-lmi-Tag.zip
"
subpackages="
	$pkgname-nonfree-firmware:nonfree_firmware
	$pkgname-nonfree-firmware-openrc:nonfree_firmware_openrc
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	# device-specific alsa ucm conf
	install -Dm644 "$srcdir/lmi.conf" \
		"$pkgdir/usr/share/alsa/ucm2/Xiaomi/lmi/lmi.conf"

	install -Dm644 "$srcdir/HiFi.conf" \
		"$pkgdir/usr/share/alsa/ucm2/Xiaomi/lmi/HiFi.conf"

	mkdir -p "$pkgdir/usr/share/alsa/ucm2/conf.d/sm8250"
	ln -s ../../Xiaomi/lmi/lmi.conf \
		"$pkgdir/usr/share/alsa/ucm2/conf.d/sm8250/xiaomi-lmi.conf"
}

nonfree_firmware() {
	pkgdesc="GPU, venus, modem and sensor firmware"
	depends="
		firmware-xiaomi-lmi
		firmware-qcom-adreno-a650
		linux-firmware-qcom
		linux-firmware-qca
		linux-firmware-ath11k
		tqftpserv
	"
	mkdir "$subpkgdir"

	install -Dm644 "$srcdir"/81-libssc-xiaomi-lmi.rules \
		"$subpkgdir"/etc/udev/rules.d/81-libssc-xiaomi-lmi.rules

	install -Dm644 "$srcdir"/hexagonrpcd.confd \
		"$subpkgdir"/usr/share/hexagonrpcd/hexagonrpcd-sdsp.conf

	# Cirrus Logic audio DSP firmware (del zip local)
	mkdir -p "$subpkgdir/lib/firmware/cirrus"
	unzip -j -o "$srcdir/firmware-xiaomi-lmi-Tag.zip" \
		"firmware-xiaomi-lmi-Tag/lib/firmware/cirrus/*" \
		-d "$subpkgdir/lib/firmware/cirrus"

	# Focaltech touch panel firmware (del zip local)
	mkdir -p "$subpkgdir/lib/firmware/focaltech"
	unzip -j -o "$srcdir/firmware-xiaomi-lmi-Tag.zip" \
		"firmware-xiaomi-lmi-Tag/lib/firmware/focaltech/*" \
		-d "$subpkgdir/lib/firmware/focaltech"

	find "$subpkgdir" -type f -exec chmod 0644 {} \;
}

nonfree_firmware_openrc() {
	install_if="$pkgname-nonfree-firmware=$pkgver-r$pkgrel openrc"
	install="$subpkgname.post-install $subpkgname.post-upgrade"
	depends="
		hexagonrpcd-openrc
		tqftpserv-openrc
	"
	mkdir -p "$subpkgdir"
}
