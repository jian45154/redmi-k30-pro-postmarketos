6ef602215801a725ae01898c4a69a60902850194b16f32aa8d49b30b2268db842e91135415deac37aa184fecab8d1a42f34258a511a5564e552c3ef4858e1c04  config-postmarketos-qcom-sm8250-lmi.aarch64
adae699bc4d7133d76816b35c262591e7d10d1a29196e0af11edad9a73663575eed968ce5c3ecebff47cd9fa7dd557f42fb73f56f6d9366987c62f17c3ec4c5f  0001-sm8250-xiaomi-lmi-enable-sdx55-modem.patch
