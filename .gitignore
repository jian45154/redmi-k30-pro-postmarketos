# Raw device logs — contain serial numbers, CPU IDs, bootloader tokens
logs/*.txt
logs/*.tmp
!logs/*.redacted.txt

# Large / third-party binary images — keep local, do NOT publish
# (stock boot.img, skkk recovery images, and pmOS build artifacts)
artifacts/images/*.img
artifacts/images/*.zip
artifacts/images/*DO-NOT-FLASH*
artifacts/images/*REJECTED*

# Stray/empty scratch files
/Running

# Local private operator/device notes — do not publish
/private/
/hardware-debug-*/

# Local Superpowers execution ledger and review handoffs
/.superpowers/

# Generated P1 work and image-verification outputs
/.work/
/artifacts/builds/
/artifacts/download-verification/
